# ====== Servidor ======
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ====== Email ======

# Brevo (TOTALMENTE GRATIS - 300 emails/día)
# Crea cuenta en: https://www.brevo.com
# Ve a Settings > SMTP & API > Create API Key
BREVO_API_KEY=
EMAIL_FROM=tu-email@tudominio.com
EMAIL_TO=destino@tudominio.com

# Poner en true para saltear el envío real (útil en desarrollo)
MOCK_EMAIL=true

# ====== Seguridad / límites ======
JWT_SECRET=cambia-esto-por-un-secreto-seguro
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ====== Logs ======
LOG_LEVEL=info
